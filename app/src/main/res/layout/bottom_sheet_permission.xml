<?xml version="1.0" encoding="utf-8"?>
<!--
    Bottom sheet used to explain a permission restriction in depth,
    typically in response to a user tapping a disabled affordance.
    Kept intentionally simple — an icon, a title, a description, and an
    optional dismiss action.
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/permission_sheet_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_lock"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/permission_sheet_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            tools:text="Read-only mode" />

        <TextView
            android:id="@+id/permission_sheet_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="You can't send messages right now." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/permission_sheet_dismiss"
            style="?attr/materialButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="16dp"
            android:text="@android:string/ok" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
