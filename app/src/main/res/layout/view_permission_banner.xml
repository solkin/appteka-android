<?xml version="1.0" encoding="utf-8"?>
<!--
    Material 3 Expressive-style banner used to surface an ACL restriction
    scoped to the surrounding screen (e.g. read-only chat). Sits above the
    content, uses secondary-container colour so it blends with the surface
    without competing for attention.
-->
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSecondaryContainer"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/permission_banner_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_lock"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="?attr/colorOnSecondaryContainer" />

        <TextView
            android:id="@+id/permission_banner_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSecondaryContainer"
            tools:text="Read-only mode"
            app:layout_constraintStart_toEndOf="@id/permission_banner_icon"
            app:layout_constraintEnd_toStartOf="@id/permission_banner_action"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/permission_banner_body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSecondaryContainer"
            tools:text="You can't send messages right now."
            app:layout_constraintStart_toEndOf="@id/permission_banner_icon"
            app:layout_constraintEnd_toStartOf="@id/permission_banner_action"
            app:layout_constraintTop_toBottomOf="@id/permission_banner_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/permission_banner_action"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:visibility="gone"
            android:text="@string/permission_banner_details_cta"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
