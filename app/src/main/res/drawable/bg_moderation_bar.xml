<?xml version="1.0" encoding="utf-8"?>
<!--
  Rounded-top surface for the moderation action bar — Material 3
  Expressive elevates the bar above the content with a clearly
  defined container instead of a flat strip.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners
        android:topLeftRadius="20dp"
        android:topRightRadius="20dp" />
    <solid android:color="?attr/colorSurfaceContainer" />
</shape>
